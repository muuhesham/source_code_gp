# Optional Docker Compose variables (used for port overrides / profiles)
COMPOSE_PROJECT_NAME=fa3liat

# Exposed ports on the host machine
PORT=3000
FRONT_PORT=5173
DB_PORT=5434
REDIS_PORT=6381
MAIL_UI_PORT=8028
MAIL_SMTP_PORT=1025
OLLAMA_PORT=11436

# Optional profiles to enable (comma-separated): ai,stripe
# COMPOSE_PROFILES=ai

# AI model (only used when `ai` profile is enabled)
OLLAMA_MODEL=nomic-embed-text-v2-moe:latest

# Stripe (only required when `stripe` profile is enabled)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
